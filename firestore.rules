rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(email) {
      return isSignedIn() && request.auth.token.email == email && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Achievement Validation
    function isValidAchievement(data, isUpdate) {
      let coreKeys = ['text', 'timestamp', 'type', 'userId'];
      return data.keys().hasAll(coreKeys) &&
             (data.keys().size() == 4 || (data.keys().size() == 5 && data.keys().hasAll(['status']))) &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 1000 &&
             data.type in ['work', 'personal', 'growth', 'thought', 'other'] &&
             data.userId == request.auth.uid &&
             (isUpdate ? true : data.timestamp == request.time) &&
             (!data.keys().hasAll(['status']) || data.status in ['published', 'draft']);
    }

    match /achievements/{achievementId} {
      // Public read for published, private for drafts
      allow read: if (resource.data.get('status', 'published') == 'published') || isOwner('maximion96@gmail.com');
      
      // Only the specific owner can write
      allow create: if isOwner('maximion96@gmail.com') && 
                      isValidAchievement(incoming(), false);
      
      allow update: if isOwner('maximion96@gmail.com') && 
                      isValidAchievement(incoming(), true) &&
                      incoming().userId == existing().userId &&
                      incoming().timestamp == existing().timestamp &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['text', 'type', 'status']);

      allow delete: if isOwner('maximion96@gmail.com');
    }
  }
}
